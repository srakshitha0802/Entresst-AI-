        </TabsContent>

        <TabsContent value="complexity" className="space-y-4">
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <BarChart3 className="w-5 h-5" />
                  Time Complexity Comparison
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="h-[300px]">
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={COMPLEXITY_DATA}>
                      <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.1)" />
                      <XAxis dataKey="name" stroke="rgba(255,255,255,0.5)" fontSize={10} angle={-45} textAnchor="end" height={80} />
                      <YAxis stroke="rgba(255,255,255,0.5)" />
                      <Tooltip contentStyle={{ backgroundColor: 'hsl(var(--card))', border: '1px solid hsl(var(--border))' }} />
                      <Bar dataKey="best" fill="#22c55e" name="Best" />
                      <Bar dataKey="average" fill="#eab308" name="Average" />
                      <Bar dataKey="worst" fill="#ef4444" name="Worst" />
                    </BarChart>
                  </ResponsiveContainer>
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Layers className="w-5 h-5" />
                  Algorithm Categories
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-4">
                  <div className="p-4 rounded-lg bg-purple-500/10 border border-purple-500/20">
                    <h4 className="font-semibold text-purple-400 flex items-center gap-2">
                      <ArrowUpDown className="w-4 h-4" />
                      Sorting Algorithms
                    </h4>
                    <p className="text-sm text-muted-foreground mt-1">
                      Bubble, Selection, Insertion, Merge, Quick, Heap, Radix Sort
                    </p>
                  </div>
                  <div className="p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
                    <h4 className="font-semibold text-blue-400 flex items-center gap-2">
                      <Search className="w-4 h-4" />
                      Searching Algorithms
                    </h4>
                    <p className="text-sm text-muted-foreground mt-1">
                      Linear Search, Binary Search
                    </p>
                  </div>
                  <div className="p-4 rounded-lg bg-green-500/10 border border-green-500/20">
                    <h4 className="font-semibold text-green-400 flex items-center gap-2">
                      <Network className="w-4 h-4" />
                      Graph Algorithms
                    </h4>
                    <p className="text-sm text-muted-foreground mt-1">
                      BFS, DFS, Dijkstra's, A* Search
                    </p>
                  </div>
              </CardContent>
            </Card>
          </div>
        </TabsContent>

        <TabsContent value="playground" className="space-y-4">
          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <Terminal className="w-5 h-5" />
                Algorithm Playground
              </CardTitle>
              <CardDescription>
                Test algorithms with custom input
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <label className="text-sm font-medium mb-2 block">Custom Input (for target search)</label>
                <Input
                  type="number"
                  placeholder="Enter target value for search algorithms"
                  value={customInput}
                  onChange={(e) => setCustomInput(e.target.value)}
                />
              </div>
              <div className="flex gap-2">
                <Button onClick={runPlaygroundCode}>
                  <PlayCircle className="w-4 h-4 mr-2" />
                  Run Algorithm
                </Button>
                <Button variant="outline" onClick={() => setPlaygroundResult('')}>
                  <RefreshCw className="w-4 h-4 mr-2" />
                  Clear
                </Button>
              </div>
              {playgroundResult && (
                <div className="p-4 rounded-lg bg-slate-950 border border-slate-800">
                  <pre className="text-sm font-mono text-green-400 whitespace-pre-wrap">{playgroundResult}</pre>
                </div>
              )}
            </CardContent>
          </Card>
        </TabsContent>

        <TabsContent value="learn" className="space-y-4">
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Lightbulb className="w-5 h-5 text-amber-400" />
                  When to Use Each Algorithm
                </CardTitle>
              </CardHeader>
              <CardContent className="space-y-3">
                {selectedAlgo?.useCases?.map((useCase, i) => (
                  <div key={i} className="p-3 rounded-lg bg-amber-400/10 flex items-center gap-2">
                    <CheckCircle className="w-4 h-4 text-amber-400 shrink-0" />
                    <span className="text-sm">{useCase}</span>
                  </div>
                ))}
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <BookOpen className="w-5 h-5 text-blue-400" />
                  Interview Tips
                </CardTitle>
              </CardHeader>
              <CardContent className="space-y-3">
                {selectedAlgo?.interviewTips?.map((tip, i) => (
                  <div key={i} className="p-3 rounded-lg bg-blue-400/10 flex items-center gap-2">
                    <Lightbulb className="w-4 h-4 text-blue-400 shrink-0" />
                    <span className="text-sm">{tip}</span>
                  </div>
                ))}
              </CardContent>
            </Card>
          </div>

          <Card>
            <CardHeader>
              <CardTitle>Algorithm Selection Guide</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="overflow-x-auto">
                <table className="w-full text-sm">
                  <thead>
                    <tr className="border-b">
                      <th className="text-left p-2">Algorithm</th>
                      <th className="text-left p-2">Best</th>
                      <th className="text-left p-2">Average</th>
                      <th className="text-left p-2">Worst</th>
                      <th className="text-left p-2">Space</th>
                      <th className="text-left p-2">Stable</th>
                    </tr>
                  </thead>
                  <tbody>
                    {ALGORITHMS.slice(0, 7).map(algo => (
                      <tr key={algo.id} className="border-b border-border">
                        <td className="p-2 font-medium">{algo.name}</td>
                        <td className="p-2 text-green-400">{algo.timeComplexityBest}</td>
                        <td className="p-2 text-yellow-400">{algo.timeComplexityAverage}</td>
                        <td className="p-2 text-red-400">{algo.timeComplexityWorst}</td>
                        <td className="p-2 text-blue-400">{algo.spaceComplexity}</td>
                        <td className="p-2">{['bubble-sort', 'insertion-sort', 'merge-sort'].includes(algo.id) ? '✓' : '✗'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>
        </TabsContent>
      </Tabs>
    </div>
  );
}
